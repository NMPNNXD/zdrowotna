<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Data -->
        <TextView
            android:id="@+id/dateText"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Licznik -->
        <TextView
            android:id="@+id/glassCounter"
            android:text="0/8"
            android:textSize="24sp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Przyciski -->
        <Button
            android:id="@+id/addButton"
            android:text="Dodaj szklankę"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/removeButton"
            android:text="Odejmij szklankę"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/resetButton"
            android:text="Restartuj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Panel nastroju -->
        <TextView
            android:text="Jak się dziś czujesz?"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/loveBtn"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="😍" />

            <Button
                android:id="@+id/happyBtn"
                android:text="😊"
                android:layout_width="60dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/neutralBtn"
                android:text="😐"
                android:layout_width="60dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/sadBtn"
                android:text="😢"
                android:layout_width="60dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/angryBtn"
                android:text="😡"
                android:layout_width="60dp"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <Button
            android:id="@+id/historyButton"
            android:text="Zobacz Historię"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Wskazówka -->
        <TextView
            android:id="@+id/tipText"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/newTipButton"
            android:text="Nowa wskazówka"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>